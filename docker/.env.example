# --- Docker Compose image tags (defaults match docker-compose.yml) ---
POSTGRES_IMAGE_TAG=16-alpine
CLICKHOUSE_IMAGE_TAG=24.8
NATS_IMAGE_TAG=2.10-alpine
REDIS_IMAGE_TAG=7-alpine

# --- PostgreSQL ---
POSTGRES_USER=agentfirewall
POSTGRES_PASSWORD=agentfirewall
POSTGRES_DB=agentfirewall
POSTGRES_PORT=5432

# --- ClickHouse ---
CLICKHOUSE_DB=agentfirewall
CLICKHOUSE_USER=agentfirewall
CLICKHOUSE_PASSWORD=agentfirewall
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# --- NATS (JetStream enabled in compose) ---
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222

# --- Redis ---
REDIS_PORT=6379

# --- Published ports for agentfirewall-server ---
AGENTVAULT_HTTP_PORT=8080
AGENTVAULT_GRPC_PORT=50051
AGENTVAULT_METRICS_PORT=9090

# --- Rust / logging (used by agentfirewall-server container) ---
RUST_LOG=info

# --- Server config (crates/agentfirewall-server/src/config.rs) ---
# Required when running the server outside Compose (Compose sets these via environment:).
# AV_DATABASE_URL=postgres://agentfirewall:agentfirewall@127.0.0.1:5432/agentfirewall
# AV_REDIS_URL=redis://127.0.0.1:6379/0
# AV_NATS_URL=nats://127.0.0.1:4222
# AV_CLICKHOUSE_URL=http://127.0.0.1:8123
#
# Bind addresses (defaults shown; must match published ports in Docker).
# AV_LISTEN_ADDR=0.0.0.0:8080
# AV_GRPC_ADDR=0.0.0.0:50051
# AV_METRICS_ADDR=0.0.0.0:9090
#
# AV_HTTP_API_ENABLED=true
# AV_MAX_DB_CONNECTIONS=20
# AV_REQUEST_TIMEOUT_SECS=30
# AV_CORS_ORIGINS=
# AV_TLS_CERT_PATH=
# AV_TLS_KEY_PATH=
# AV_IDEMPOTENCY_TTL_SECS=300
